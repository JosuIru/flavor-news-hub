<?xml version="1.0" encoding="utf-8"?>
<!-- "Display" del dial: una ventanita con tono ámbar/LED tipo pantalla
     retro, con brillo interior sutil. El texto va en monospace encima. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="6dp" />
    <gradient
        android:type="linear"
        android:angle="270"
        android:startColor="#1a1204"
        android:endColor="#2a1d0a" />
    <stroke android:width="1dp" android:color="#c08a2e" />
</shape>
