<?xml version="1.0" encoding="utf-8"?>
<!-- Botón de "mando" circular: tono cobre/latón + borde oscuro para
     efecto metálico. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <gradient
        android:type="radial"
        android:gradientRadius="30dp"
        android:centerX="0.35"
        android:centerY="0.35"
        android:startColor="#d4a86a"
        android:endColor="#7a5428" />
    <stroke android:width="1dp" android:color="#3e2711" />
</shape>
