<?xml version="1.0" encoding="utf-8"?>
<!-- Pill del widget de búsqueda: fondo claro con esquinas completamente
     redondeadas (alto / 2) para el efecto "pastilla" tipo Google Quick
     Search Box. Usamos un radio grande que se recorta al mitad del alto
     real por Android. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="100dp" />
    <solid android:color="#FFFFFF" />
    <stroke android:width="1dp" android:color="#E5E5EA" />
</shape>
