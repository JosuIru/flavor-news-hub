<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_fondo"
    android:padding="10dp">

    <TextView
        android:id="@+id/fav_cabecera"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/widget_favoritos_cabecera"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        android:textSize="13sp"
        android:paddingBottom="6dp" />

    <LinearLayout
        android:id="@+id/fav_fila_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="6dp">
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_lock_silent_mode_off"
            android:layout_marginEnd="8dp"
            android:contentDescription="@null" />
        <TextView
            android:id="@+id/fav_1_nombre"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="@android:color/white"
            android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/fav_fila_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="6dp">
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_lock_silent_mode_off"
            android:layout_marginEnd="8dp"
            android:contentDescription="@null" />
        <TextView
            android:id="@+id/fav_2_nombre"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="@android:color/white"
            android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/fav_fila_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="6dp">
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_lock_silent_mode_off"
            android:layout_marginEnd="8dp"
            android:contentDescription="@null" />
        <TextView
            android:id="@+id/fav_3_nombre"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="@android:color/white"
            android:textSize="13sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/fav_vacio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/widget_favoritos_vacio"
        android:textColor="#CCE0E0E0"
        android:textSize="11sp"
        android:visibility="gone"
        android:paddingTop="8dp" />
</LinearLayout>
