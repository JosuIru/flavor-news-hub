<?xml version="1.0" encoding="utf-8"?>
<!-- Preview del widget de radio: enseña cómo se verá con una radio
     sonando, no el estado "sin radio" que no vende el widget. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/widget_fondo"
    android:padding="12dp">

    <ImageView
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@android:drawable/ic_media_pause"
        android:layout_marginEnd="10dp"
        android:contentDescription="@null" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/widget_preview_radio_meta"
            android:textColor="#CCE0E0E0"
            android:textSize="10sp"
            android:maxLines="1" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/widget_preview_radio_nombre"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="13sp"
            android:maxLines="1" />
    </LinearLayout>

    <ImageView
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@android:drawable/ic_media_pause"
        android:contentDescription="@null" />
    <ImageView
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@android:drawable/ic_lock_power_off"
        android:contentDescription="@null" />
</LinearLayout>
