<?xml version="1.0" encoding="utf-8"?>
<!--
  Widget "Sintonizador": radio antigua de madera.
  Layout: cabecera + display del dial + fila de botones ◄ ■ ▶ ►.
  Los botones son clickables; el dial entero abre la pantalla de radios.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/sintonizador_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/sintonizador_fondo"
    android:padding="14dp">

    <TextView
        android:id="@+id/sintonizador_cabecera"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="@string/widget_sintonizador_cabecera"
        android:textColor="#f0d89a"
        android:textStyle="bold"
        android:textSize="11sp"
        android:letterSpacing="0.15"
        android:paddingBottom="8dp" />

    <!-- Display del dial: fondo oscuro + nombre radio en ámbar.
         Es tappable → abre /audio en la app para escuchar. -->
    <LinearLayout
        android:id="@+id/sintonizador_dial"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/sintonizador_dial"
        android:padding="10dp"
        android:minHeight="58dp"
        android:gravity="center">

        <TextView
            android:id="@+id/sintonizador_nombre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:ellipsize="end"
            android:gravity="center"
            android:textColor="#ffc870"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:shadowColor="#ff8800"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="3" />

        <TextView
            android:id="@+id/sintonizador_territorio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:ellipsize="end"
            android:gravity="center"
            android:textColor="#c89e5a"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:paddingTop="2dp" />

    </LinearLayout>

    <!-- LEDs de posición: 8 puntos horizontales, el activo brilla. -->
    <TextView
        android:id="@+id/sintonizador_leds"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:paddingTop="6dp"
        android:paddingBottom="4dp"
        android:textColor="#8a6634"
        android:textSize="13sp"
        android:fontFamily="monospace"
        android:letterSpacing="0.3"
        android:text="· · · · · · · · · ·" />

    <!-- Botones: anterior / stop / play / siguiente.
         Cada uno con padding generoso para cumplir el mínimo de 48dp. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_horizontal"
        android:paddingTop="6dp">

        <ImageButton
            android:id="@+id/sintonizador_btn_anterior"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/sintonizador_boton"
            android:src="@android:drawable/ic_media_rew"
            android:scaleType="center"
            android:contentDescription="@string/widget_sintonizador_anterior" />

        <ImageButton
            android:id="@+id/sintonizador_btn_stop"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/sintonizador_boton"
            android:src="@android:drawable/ic_lock_power_off"
            android:scaleType="center"
            android:contentDescription="@string/widget_sintonizador_stop" />

        <ImageButton
            android:id="@+id/sintonizador_btn_play"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/sintonizador_boton"
            android:src="@android:drawable/ic_media_play"
            android:scaleType="center"
            android:contentDescription="@string/widget_sintonizador_play" />

        <ImageButton
            android:id="@+id/sintonizador_btn_siguiente"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/sintonizador_boton"
            android:src="@android:drawable/ic_media_ff"
            android:scaleType="center"
            android:contentDescription="@string/widget_sintonizador_siguiente" />

    </LinearLayout>

</LinearLayout>
