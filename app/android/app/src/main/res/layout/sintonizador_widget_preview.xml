<?xml version="1.0" encoding="utf-8"?>
<!-- Preview para el selector de widgets: misma radio con datos fake. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/sintonizador_fondo"
    android:padding="14dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="@string/widget_sintonizador_cabecera"
        android:textColor="#f0d89a"
        android:textStyle="bold"
        android:textSize="11sp"
        android:letterSpacing="0.15"
        android:paddingBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/sintonizador_dial"
        android:padding="10dp"
        android:minHeight="58dp"
        android:gravity="center">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:gravity="center"
            android:text="@string/widget_preview_radio_nombre"
            android:textColor="#ffc870"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:shadowColor="#ff8800"
            android:shadowDx="0" android:shadowDy="0" android:shadowRadius="3" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:gravity="center"
            android:text="@string/widget_preview_radio_meta"
            android:textColor="#c89e5a"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:paddingTop="2dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="#c89e5a"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.1"
            android:paddingTop="2dp"
            android:text="▁▃▅▇▅▃▁" />

    </LinearLayout>

    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:paddingTop="6dp"
        android:paddingBottom="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#ffc870"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.3"
            android:text="· · · ◉ · · · · · ·" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#ff3838"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.3"
            android:text="      │            " />
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_horizontal"
        android:paddingTop="6dp">

        <TextView android:layout_width="40dp" android:layout_height="40dp"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/sintonizador_boton"
            android:gravity="center" android:text="⏮"
            android:textSize="18sp" android:textColor="#2a1a08"
            android:contentDescription="@null" />
        <TextView android:layout_width="40dp" android:layout_height="40dp"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/sintonizador_boton"
            android:gravity="center" android:text="⏹"
            android:textSize="18sp" android:textColor="#2a1a08"
            android:contentDescription="@null" />
        <TextView android:layout_width="40dp" android:layout_height="40dp"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/sintonizador_boton"
            android:gravity="center" android:text="▶"
            android:textSize="18sp" android:textColor="#2a1a08"
            android:contentDescription="@null" />
        <TextView android:layout_width="40dp" android:layout_height="40dp"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/sintonizador_boton"
            android:gravity="center" android:text="⏭"
            android:textSize="18sp" android:textColor="#2a1a08"
            android:contentDescription="@null" />
    </LinearLayout>

</LinearLayout>
