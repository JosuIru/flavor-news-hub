<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/widget_fondo"
    android:padding="10dp">

    <ImageView
        android:id="@+id/musica_portada"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginEnd="10dp"
        android:scaleType="centerCrop"
        android:background="#333"
        android:contentDescription="@string/widget_musica_portada"
        android:src="@android:drawable/ic_media_play" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/musica_cabecera"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/widget_musica_cabecera"
            android:textColor="#CCE0E0E0"
            android:textSize="10sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/musica_titulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/widget_musica_sin_pista"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/musica_artista"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#CCE0E0E0"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginStart="6dp">

        <ImageButton
            android:id="@+id/musica_btn_prev"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?android:selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_previous"
            android:contentDescription="Anterior" />

        <ImageButton
            android:id="@+id/musica_btn_playpause"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?android:selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_play"
            android:contentDescription="@string/widget_radio_play" />

        <ImageButton
            android:id="@+id/musica_btn_next"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?android:selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_next"
            android:contentDescription="Siguiente" />
    </LinearLayout>

    <ImageView
        android:id="@+id/musica_icon_estado"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@android:drawable/ic_media_play"
        android:layout_marginStart="6dp"
        android:visibility="gone"
        android:contentDescription="@string/widget_musica_estado" />
</LinearLayout>
