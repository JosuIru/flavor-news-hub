<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Reproducción en primer plano de las radios libres -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- El widget de música descarga portadas en background desde Kotlin. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Android 13+ exige permiso runtime para enviar notificaciones; lo
         pide flutter_local_notifications al inicializar. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Instalar el APK descargado desde la propia app (flujo OTA). -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <application
        android:label="Flavor News Hub"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="false">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:supportsPictureInPicture="true"
            android:resizeableActivity="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <!-- Recibir "Compartir a Flavor News Hub" desde otras apps.
                 El usuario comparte una URL, nosotros abrimos el formulario
                 de proponer medio con la URL ya rellenada. -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
            <!-- Deep links `flavornews://` para atajos desde widgets. -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="flavornews" />
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

        <!-- just_audio_background / audio_service: servicio en primer plano
             para que las radios sigan sonando con pantalla bloqueada y
             muestren controles en la notificación del sistema. -->
        <service
            android:name="com.ryanheise.audioservice.AudioService"
            android:foregroundServiceType="mediaPlayback"
            android:exported="true">
            <intent-filter>
                <action android:name="android.media.browse.MediaBrowserService" />
            </intent-filter>
        </service>
        <receiver
            android:name="com.ryanheise.audioservice.MediaButtonReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MEDIA_BUTTON" />
            </intent-filter>
        </receiver>

        <!-- Widget de pantalla de inicio: últimos titulares. Flutter escribe
             los datos; este provider los pinta. -->
        <receiver
            android:name=".TitularesWidgetProvider"
            android:exported="true"
            android:label="@string/widget_titulares_cabecera">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/titulares_widget_info" />
        </receiver>

        <!-- Widget de pantalla de inicio: radio actual. -->
        <receiver
            android:name=".ReproductorRadioWidgetProvider"
            android:exported="true"
            android:label="@string/widget_radio_cabecera">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/reproductor_radio_widget_info" />
        </receiver>

        <!-- Widget de pantalla de inicio: reproductor de música. -->
        <receiver
            android:name=".ReproductorMusicaWidgetProvider"
            android:exported="true"
            android:label="@string/widget_musica_cabecera">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/reproductor_musica_widget_info" />
        </receiver>

        <!-- Widget de pantalla de inicio: radios favoritas como atajos. -->
        <receiver
            android:name=".FavoritosWidgetProvider"
            android:exported="true"
            android:label="@string/widget_favoritos_cabecera">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/favoritos_widget_info" />
        </receiver>

        <!-- Widget de pantalla de inicio: barra de búsqueda. Pill tipo
             Google Quick Search Box con el icono de la app + placeholder.
             Al tocar abre /search vía flavornews://search. -->
        <receiver
            android:name=".BuscadorWidgetProvider"
            android:exported="true"
            android:label="@string/widget_buscador_descripcion">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/buscador_widget_info" />
        </receiver>

        <!-- Widget sintonizador: radio antigua de madera con ◄ ■ ▶ ►
             para cambiar entre emisoras sin abrir la app. -->
        <receiver
            android:name=".SintonizadorWidgetProvider"
            android:exported="true"
            android:label="@string/widget_sintonizador_cabecera">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="org.flavornewshub.flavor_news_hub.SINTONIZADOR_ANTERIOR" />
                <action android:name="org.flavornewshub.flavor_news_hub.SINTONIZADOR_SIGUIENTE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/sintonizador_widget_info" />
        </receiver>

        <!-- Deep link handler desde el widget (pulsar titular → detalle).
             El Receiver delega en un Service; ambos tienen que estar
             declarados o Android revienta con:
             "No such service ComponentInfo{... HomeWidgetBackgroundService}" -->
        <receiver
            android:name="es.antonborri.home_widget.HomeWidgetBackgroundReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="es.antonborri.home_widget.action.BACKGROUND" />
            </intent-filter>
        </receiver>
        <service
            android:name="es.antonborri.home_widget.HomeWidgetBackgroundService"
            android:permission="android.permission.BIND_JOB_SERVICE"
            android:exported="false" />

        <!-- FileProvider para pasar el APK descargado (en cacheDir) al
             instalador de paquetes del sistema. Android exige que el
             path venga de un content:// Uri gestionado por un
             FileProvider propio; no se puede usar file:// desde
             N en adelante. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="org.flavornewshub.flavor_news_hub.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <!-- url_launcher: abrir enlaces en el navegador externo. -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="http" />
        </intent>
        <!-- url_launcher: abrir mailto si algún día lo usamos. -->
        <intent>
            <action android:name="android.intent.action.SENDTO" />
            <data android:scheme="mailto" />
        </intent>
        <!-- Instalador de paquetes: necesario en Android 11+ para que
             el intent VIEW sobre el MIME de APK pueda resolverse. -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:mimeType="application/vnd.android.package-archive" />
        </intent>
    </queries>
</manifest>
