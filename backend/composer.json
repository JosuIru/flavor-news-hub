{
  "name": "flavor-news-hub/backend",
  "description": "Backend WordPress (plugin headless) de Flavor News Hub: CPTs, ingesta RSS y API REST pública.",
  "type": "wordpress-plugin",
  "license": "AGPL-3.0-or-later",
  "homepage": "https://github.com/JosuIru/flavor-news-hub",
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "yoast/phpunit-polyfills": "^2.0",
    "wp-coding-standards/wpcs": "^3.0",
    "squizlabs/php_codesniffer": "^3.9"
  },
  "scripts": {
    "test": "phpunit --configuration phpunit.xml.dist",
    "test:coverage": "phpunit --configuration phpunit.xml.dist --coverage-html coverage"
  },
  "autoload": {
    "psr-4": {
      "FlavorNewsHub\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "FlavorNewsHub\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
